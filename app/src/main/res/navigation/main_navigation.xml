<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="ubaya.example.habittracker.view.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="ubaya.example.habittracker.view.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/actionCreateHabitFragment"
            app:destination="@id/createHabitFragment" />

        <action
            android:id="@+id/actionEditHabitFragment"
            app:destination="@id/editHabitFragment" />
    </fragment>

    <fragment
        android:id="@+id/createHabitFragment"
        android:name="ubaya.example.habittracker.view.CreateHabitFragment"
        android:label="Create Habit"
        tools:layout="@layout/fragment_create_habit" />

    <fragment
        android:id="@+id/editHabitFragment"
        android:name="ubaya.example.habittracker.view.EditHabitFragment"
        android:label="Edit Habit"
        tools:layout="@layout/fragment_edit_habit" />

</navigation>